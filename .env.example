# --- Datenbank (MySQL/MariaDB, lokal) ---
# Format: mysql://BENUTZER:PASSWORT@HOST:PORT/DATENBANK
# Passwort mit Sonderzeichen muss URL-enkodiert werden (z.B. @ -> %40).
DATABASE_URL="mysql://hairy_booking:DEIN_PASSWORT@localhost:3306/hairy_booking"

# --- Initialer Owner-Account (wird vom Seed angelegt) ---
OWNER_EMAIL="owner@example.ch"
OWNER_PASSWORD="bitte-aendern-min-10-zeichen"
OWNER_FIRST_NAME="Admin"
OWNER_LAST_NAME="Owner"

# --- Web-Push (VAPID) ---
# Schluesselpaar generieren mit:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Ohne diese Variablen ist Push deaktiviert (App funktioniert normal weiter).
VAPID_SUBJECT="mailto:owner@example.ch"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
